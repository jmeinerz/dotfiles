[init]
  templatedir = ~/.git-template
[user]
  name = Jonas Meinerz
  email = jonas@thoughtbot.com
[push]
  default = current
[commit]
  template = ~/.gitmessage
[fetch]
  prune = true
[alias]
  glog = log -E -i --grep
  pf = push --force-with-lease
[pull]
  ff = only
[includeIf "gitdir:~/Qonto/"]
  path = ~/Qonto/gitconfig
